    {
      "path": "Repu_Data/locales/deDE.lua",
      "category": "locale_content_domain",
      "matchCount": 114,
      "matches": [
        {
          "line": 10,
          "value": "Startdatensatz für diese im Retail-Core lokal verankerte Fraktion. Der Kernbezug liegt aktuell vor allem bei Schlingendorntal, Nördliches Schlingendorntal, Das Schlingendornkap. Spezifische Rüstmeister- und Aktivitätsdaten können später präzisiert werden.",
          "markers": [
            "non_ascii"
          ]
        },
        {
          "line": 16,
          "value": "Eisenschmiede",
          "markers": [
            "eisenschmiede"
          ]
        },
        {
          "line": 19,
          "value": "Klassische Zwergenfraktion von Eisenschmiede. In Retail taucht sie vor allem in Eisenschmiede, Dun Morogh, Loch Modan und angrenzenden Allianz-Gebieten als lokale Heimatfraktion auf.",
          "markers": [
            "eisenschmiede"
          ]
        },
        {
          "line": 25,
          "value": "Sengende Schlucht",
          "markers": [
            "sengende schlucht"
          ]
        },
        {
          "line": 32,
          "value": "Die Thoriumbruderschaft deckt im Retail-Core vor allem die Blackrock-Gebiete rund um Sengende Schlucht und Brennende Steppe ab.",
          "markers": [
            "sengende schlucht"
          ]
        },
        {
          "line": 38,
          "value": "Unterstadt",
          "markers": [
            "unterstadt"
          ]
        },
        {
          "line": 41,
          "value": "Klassische Untotenfraktion von Unterstadt. In Retail taucht sie vor allem in Tirisfal, Silberwald, Unterstadt und angrenzenden Gebieten als lokale Heimatfraktion auf.",
          "markers": [
            "unterstadt"
          ]
        },
        {
          "line": 50,
          "value": "Legacy-Hauptstadtfraktion von Darnassus. Im Retail-Core bleibt sie als klassische Allianz-Stadtfraktion erhalten, auch wenn die Stadt selbst heute nur noch in Legacy-Zusammenhängen relevant ist.",
          "markers": [
            "non_ascii"
          ]
        },
        {
          "line": 56,
          "value": "Sturmwind",
          "markers": [
            "sturmwind"
          ]
        },
        {
          "line": 59,
          "value": "Klassische Menschenfraktion von Sturmwind. In Retail taucht sie in Sturmwind, Elwynn, Westfall, Rotkamm und angrenzenden Allianz-Gebieten als lokale Heimatfraktion auf.",
          "markers": [
            "sturmwind"
          ]
        },
        {
          "line": 68,
          "value": "Klassische Orc-Hauptstadtfraktion von Orgrimmar. In Retail taucht sie in Orgrimmar, Durotar und Teilen des nördlichen Brachlands als lokale Heimatfraktion auf.",
          "markers": [
            "non_ascii"
          ]
        },
        {
          "line": 74,
          "value": "Donnerfels",
          "markers": [
            "donnerfels"
          ]
        },
        {
          "line": 77,
          "value": "Klassische Tauren-Hauptstadtfraktion von Donnerfels. In Retail taucht sie in Donnerfels, Mulgore und den zugehörigen Tauren-Gebieten als lokale Heimatfraktion auf.",
